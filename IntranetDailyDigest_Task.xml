  <Triggers>
    <CalendarTrigger>
      <StartBoundary>2026-01-26T08:00:00</StartBoundary>
      <Enabled>true</Enabled>
      <ScheduleByWeek>
        <WeeksInterval>1</WeeksInterval>
        <DaysOfWeek>
