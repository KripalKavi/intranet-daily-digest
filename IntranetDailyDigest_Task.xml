      <Command>C:\Users\krkavi\AppData\Local\Programs\Python\Python312\python.exe</Command>
      <Arguments>send_digest_email.py</Arguments>
      <WorkingDirectory>C:\Users\krkavi\OneDrive - Microsoft\Projects\99 - Professional development\06 - Claude Code Projects\Intranet daily mail</WorkingDirectory>
